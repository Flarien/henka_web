---
import { Image } from 'astro:assets';
import '../styles/global.css';

const social = {
	instagram: 'https://instagram.com/henka.estudio',
	facebook: 'https://facebook.com/henka.ar',
	whatsapp: 'https://wa.me/5492235710168',
};
---

<html lang='en'>
	<head>
		<meta charset='utf-8' />
		<link rel='icon' href='/favicon.png' />

		<meta name='viewport' content='width=device-width' />
		<meta name='generator' content={Astro.generator} />
		<title>Henka - Sitio en construcción</title>
	</head>
	<body
		class='min-h-screen bg-[#2e2520] text-[#e8ddd0] flex items-center justify-center px-6'
	>
		<main class='max-w-md w-full text-center'>
			<!-- Marca -->
			<Image
				src='https://res.cloudinary.com/dciovdqaf/image/upload/v1782582431/HENKA-logo-Redes_afqbxv.webp'
				alt='Henka logo'
				class='mx-auto mb-6 w-90'
				decoding='async'
				loading='lazy'
				width={1332}
				height={505}
			/>

			<!-- Signature: trazo que se "transforma" -->

			<h1 class='font-sans text-3xl sm:text-4xl leading-tight mb-4'>
				Estamos construyendo<br />algo nuevo
			</h1>

			<p
				class='text-[#B8ACA1] text-sm sm:text-base mb-10 leading-relaxed text-balance'
			>
				Mientras tanto, encontranos en nuestras redes sociales o escribinos por
				WhatsApp para cualquier consulta o ver el catálogo.
			</p>

			<!-- Redes -->
			<div class='flex justify-center gap-4 mb-6'>
				<a
					href={social.instagram}
					target='_blank'
					rel='noopener noreferrer'
					aria-label='Instagram de Henka'
					class='w-12 h-12 rounded-full border border-[#3A3331] flex items-center justify-center text-[#e8ddd0] hover:border-[#c4522a] hover:text-[#c4522a] transition-colors'
				>
					<svg
						width='20'
						height='20'
						viewBox='0 0 24 24'
						fill='none'
						stroke='currentColor'
						stroke-width='1.8'
					>
						<rect x='3' y='3' width='18' height='18' rx='5'></rect>
						<circle cx='12' cy='12' r='4'></circle>
						<circle cx='17.5' cy='6.5' r='0.8' fill='currentColor' stroke='none'
						></circle>
					</svg>
				</a>

				<a
					href={social.facebook}
					target='_blank'
					rel='noopener noreferrer'
					aria-label='Facebook de Henka'
					class='w-12 h-12 rounded-full border border-[#3A3331] flex items-center justify-center text-[#e8ddd0] hover:border-[#c4522a] hover:text-[#c4522a] transition-colors'
				>
					<svg
						width='20'
						height='20'
						viewBox='0 0 24 24'
						fill='none'
						stroke='currentColor'
						stroke-width='1.8'
					>
						<path
							d='M15 8h2V5h-2c-2.2 0-4 1.8-4 4v2H9v3h2v7h3v-7h2.2l.8-3H14V9c0-.6.4-1 1-1z'
						></path>
					</svg>
				</a>
			</div>

			<!-- CTA principal: WhatsApp -->
			<a
				href={social.whatsapp}
				target='_blank'
				rel='noopener noreferrer'
				class='inline-flex items-center gap-2 bg-[#c4522a] text-[#171312] font-medium px-6 py-3 rounded-full hover:bg-[#c4522a] transition-colors'
			>
				<svg width='18' height='18' viewBox='0 0 24 24' fill='currentColor'>
					<path
						d='M12 2C6.48 2 2 6.48 2 12c0 1.85.5 3.58 1.36 5.07L2 22l5.07-1.33A9.93 9.93 0 0012 22c5.52 0 10-4.48 10-10S17.52 2 12 2zm5.2 14.2c-.22.62-1.28 1.2-1.77 1.27-.45.07-1.02.1-1.65-.1-.38-.12-.87-.28-1.5-.55-2.64-1.14-4.36-3.8-4.5-4-.13-.2-1.08-1.44-1.08-2.74 0-1.3.68-1.93.92-2.2.24-.27.52-.33.7-.33.18 0 .35 0 .5.01.16.01.38-.06.6.46.22.53.75 1.84.82 1.97.07.13.12.29.02.46-.1.18-.15.29-.3.45-.15.16-.32.36-.46.49-.15.13-.3.27-.13.55.17.28.78 1.28 1.67 2.07 1.15 1.02 2.12 1.34 2.42 1.49.3.15.48.13.65-.05.17-.18.74-.86.94-1.16.2-.3.4-.25.66-.15.27.1 1.72.81 2.02.96.3.15.5.23.57.36.07.13.07.74-.15 1.36z'
					></path>
				</svg>
				WhatsApp
			</a>
		</main>
	</body>
</html>
